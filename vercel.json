{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/public/build/$1" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/detail/(.*)", "dest": "/public/detail/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/img/(.*)", "dest": "/public/img/$1" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/robots.txt", "dest": "/public/robots.txt" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/script.js", "dest": "/public/script.js" },
    { "src": "/placeholder.png", "dest": "/public/placeholder.png" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "buildCommand": "composer install --no-dev && npm install && npm run build"
}
